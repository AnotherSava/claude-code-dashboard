.claude/settings.local.json

# Node / Vite
node_modules
dist
dist-ssr
*.log
npm-debug.log*

# Rust / Tauri
src-tauri/target/
src-tauri/gen/schemas/

# OS
.DS_Store
*.local

# Python
__pycache__/
*.pyc

# Plans: ignore in-flight plans in docs/plans/ itself;
# keep completed/ and draft/ tracked.
/docs/plans/*
!/docs/plans/completed/
!/docs/plans/draft/

# Deploy-time config. `local.template.json` is the per-machine, secret-free
# source (secrets are {{tojson .NAME}} placeholders pulled from Doppler project
# `claude-code-dashboard`). `scripts/deploy.sh` renders it to `local.json`,
# copies that to the install dir as config.json, then wipes it — so the rendered
# secret-bearing file only ever exists transiently during a deploy.
config/local.json
config/local.template.json

# Per-machine deploy paths (INSTALL_DIR, CONFIG_DEST). Generated by the
# deploy skill; values vary across contributors' machines.
config/deploy.env

# Timestamped backups written by the cleanup skill before it wipes app data
# (BACKUP_FILES in config/deploy.env decides what gets saved).
.cleanup-backups/
