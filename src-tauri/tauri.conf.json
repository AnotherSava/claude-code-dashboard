{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Code Dashboard",
  "version": "1.6.0",
  "identifier": "com.anothersava.claude-code-dashboard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Claude Code Dashboard",
        "width": 420,
        "height": 320,
        "minWidth": 300,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "transparent": false,
        "visible": false,
        "backgroundColor": "#1c1c1e",
        "acceptFirstMouse": true
      },
      {
        "label": "history",
        "title": "History",
        "width": 450,
        "height": 400,
        "decorations": true,
        "resizable": true,
        "visible": false,
        "acceptFirstMouse": true,
        "theme": "Dark"
      },
      {
        "label": "about",
        "title": "About",
        "width": 380,
        "height": 280,
        "decorations": true,
        "resizable": false,
        "minimizable": false,
        "maximizable": false,
        "center": true,
        "skipTaskbar": true,
        "visible": false,
        "acceptFirstMouse": true,
        "alwaysOnTop": true,
        "theme": "Dark"
      },
      {
        "label": "intensity",
        "title": "Work intensity",
        "width": 1000,
        "height": 560,
        "decorations": true,
        "resizable": true,
        "visible": false,
        "acceptFirstMouse": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
